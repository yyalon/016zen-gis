{
  "extends": "@antfu",
  "rules": {
    "unused-imports/no-unused-vars": "off",
    "eslint-comments/no-unlimited-disable": "off",
    "curly": [
      "error",
      "all"
    ],
    "arrow-parens": 0,
    "brace-style": "off",
    "vue/component-tags-order": [
      "error",
      {
        "order": [
          "route",
          "script",
          "template",
          "style"
        ]
      }
    ],
    "no-console": "off"
  }
}